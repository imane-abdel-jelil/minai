VITE_MAPBOX_TOKEN=pk.PASTE_YOUR_MAPBOX_PUBLIC_TOKEN_HERE
VITE_SUPABASE_URL=https://PASTE_YOUR_SUPABASE_URL_HERE.supabase.co
VITE_SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE

# ─── UNIQUEMENT pour les scripts server-side (import geodata) ────────
# NE JAMAIS committer cette valeur. NE JAMAIS l'exposer côté frontend.
# Récupère-la sur Supabase → Settings → API → "service_role secret"
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_SECRET_HERE

# ─── Feature flag : bascule des données géo vers Supabase (chantier 1)
# false (défaut) → le frontend lit les fichiers geojson statiques
# true          → le frontend interroge Supabase (vues *_geojson)
# En cas d'échec Supabase, fallback automatique sur les fichiers.
VITE_USE_SUPABASE_GEODATA=false
